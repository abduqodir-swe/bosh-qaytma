# Bo'sh Qaytma — Backend env example
# Copy this file to `.env` and fill in real values.
# DO NOT commit the real `.env` to git.

# SQLite for local dev (creates ./bosqaytma.db automatically).
# For production swap to e.g.: postgresql+asyncpg://user:pwd@host/db
DATABASE_URL=sqlite+aiosqlite:///./bosqaytma.db

# JWT signing key. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# REQUIRED in production. Dev auto-generates if missing.
JWT_SECRET=

# Token lifetime in minutes (default = 7 days).
JWT_EXPIRES_MINUTES=10080

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# Set to "production" to enforce JWT_SECRET being set.
ENVIRONMENT=development
